NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
OPENAI_API_KEY=
DEV_AUTH_BYPASS=false

# Agent pipeline v2 — comma-separated list of workspace ids that should run
# the multi-agent pipeline in /api/generate-post. Empty (or unset) means
# every workspace gets the byte-identical v1 flow.
PIPELINE_V2_WORKSPACES=

# Per-pipeline cost ceiling in USD. When the running sum of step costs in a
# single pipeline invocation exceeds this, remaining steps are skipped and a
# blocker "pipeline.cost_cap_exceeded" flag is appended. Default: 0.50.
PIPELINE_COST_CAP_USD=0.50

# Brand feedback loop — comma-separated workspace ids allowed to pull the
# last 20 manager_edits into Brand's system prompt. Kill switch: empty (or
# unset) means every workspace runs Brand with the base prompt unchanged.
# Cache TTL is 1h per workspace, in-process.
BRAND_FEEDBACK_WORKSPACES=

# Dev-only debug toggle. Set to "true" to log the fully-assembled Brand
# system prompt on every run. In production (NODE_ENV=production) the raw
# prompt is REDACTED from logs even when this is "true" — only structured
# fields (workspaceId, editCount, promptLength, editSectionChars) emit —
# so an accidentally-enabled flag doesn't leak manager edit PII into
# application logs. Default: off.
LOG_BRAND_PROMPTS=false
