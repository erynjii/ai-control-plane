NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
OPENAI_API_KEY=
DEV_AUTH_BYPASS=false

# Agent pipeline v2 — comma-separated list of workspace ids that should run
# the multi-agent pipeline in /api/generate-post. Empty (or unset) means
# every workspace gets the byte-identical v1 flow.
PIPELINE_V2_WORKSPACES=

# Per-pipeline cost ceiling in USD. When the running sum of step costs in a
# single pipeline invocation exceeds this, remaining steps are skipped and a
# blocker "pipeline.cost_cap_exceeded" flag is appended. Default: 0.50.
PIPELINE_COST_CAP_USD=0.50
